{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "es2022",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@controllers": [
        "./src/controllers/index.ts"
      ],
      "@utils": [
        "./src/utils/index.ts"
      ],
      "@types": [
        "./src/types/index.ts"
      ],
      "@validators": [
        "./src/validators/index.ts"
      ]
    }
  }
}